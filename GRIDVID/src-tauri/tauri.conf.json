{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gridvid",
  "version": "0.1.0",
  "identifier": "com.gridvid.studio",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "gridvid",
        "width": 1320,
        "height": 860,
        "minWidth": 820,
        "minHeight": 560,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
